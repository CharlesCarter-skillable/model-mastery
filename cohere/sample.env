# =============================================================================
# cohere/sample.env  ──  Canonical reference for ALL env vars used in the
# "Cohere on Microsoft Foundry" 3-hour workshop.
#
# Lab 0's setup-env.sh copies this file to `.env` and fills in concrete values
# using Azure CLI queries against your resource group. Notebooks load `.env`
# via python-dotenv. Never commit `.env`.
#
# Variables are grouped by the lab that first consumes them.
# =============================================================================

# -----------------------------------------------------------------------------
# Azure subscription + identity (used by every lab via DefaultAzureCredential)
# -----------------------------------------------------------------------------
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_LOCATION=eastus2

# -----------------------------------------------------------------------------
# Lab 0 — Foundry resource coordinates
# -----------------------------------------------------------------------------
# Resource group containing the Foundry account + project + model deployments.
AZURE_RESOURCE_GROUP=

# Foundry account = Microsoft.CognitiveServices/accounts (kind=AIServices).
FOUNDRY_ACCOUNT_NAME=

# Foundry project = Microsoft.CognitiveServices/accounts/projects child.
FOUNDRY_PROJECT_NAME=

# Top-level AI Services endpoint, e.g. https://<account>.services.ai.azure.com
AZURE_AI_ENDPOINT=

# Project endpoint used by azure-ai-projects:
# https://<account>.services.ai.azure.com/api/projects/<project>
FOUNDRY_PROJECT_ENDPOINT=

# -----------------------------------------------------------------------------
# Lab 0 — Model deployment names (must match what Bicep deploys)
# -----------------------------------------------------------------------------
# Cohere Command A — the chat model powering the Lab 1 travel concierge agent.
COMMAND_A_DEPLOYMENT=command-a

# Cohere Embed v4 — used in Lab 2 embed exercises and Lab 1 grounding.
EMBED_V4_DEPLOYMENT=embed-v-4-0

# Cohere Rerank v4.0 Pro — used in Lab 2 rerank exercises.
RERANK_DEPLOYMENT=Cohere-rerank-v4.0-pro

# OpenAI text-embedding-3-small — used in Lab 2 for side-by-side comparisons.
OPENAI_EMBED_DEPLOYMENT=text-embedding-3-small

# API versions (override only if you know what you're doing).
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_INFERENCE_API_VERSION=2024-05-01-preview

# -----------------------------------------------------------------------------
# Lab 1 — Observability (Microsoft Agent Framework concierge)
# -----------------------------------------------------------------------------
# App Insights connection string — provisioned in Lab 0 (Bicep) and read by
# the OpenTelemetry helper so MAF traces appear in the Foundry Monitoring tab.
APPLICATIONINSIGHTS_CONNECTION_STRING=

# -----------------------------------------------------------------------------
# Lab 2 — Cohere vendor SDK env vars (RERANK + EMBED via cohere.ClientV2)
# -----------------------------------------------------------------------------
# Upstream Cohere notebooks use cohere.ClientV2(base_url=..., api_key=...)
# with the /providers/cohere endpoint pattern. The values below mirror those
# expectations; ClientV2 appends the operation path shown in each comment.
EMBED_BASE_URL=   # https://<account>.services.ai.azure.com/providers/cohere — ClientV2 appends /v2/embed
EMBED_API_KEY=    # Foundry account key 1; AAD auth also works if you replace ClientV2 with a token
EMBED_MODEL=embed-v-4-0  # vendor-parity alias for EMBED_V4_DEPLOYMENT so upstream cohere-azure-workshops notebooks run unmodified
RERANK_BASE_URL=  # same pattern as EMBED_BASE_URL — ClientV2 appends /v2/rerank
RERANK_API_KEY=   # Foundry account key 1
RERANK_MODEL=Cohere-rerank-v4.0-pro  # vendor-parity alias for RERANK_DEPLOYMENT so upstream cohere-azure-workshops notebooks run unmodified
CHROMA_DB_PATH=./chroma_db  # vendor naming; notebooks read this when they need a persistent vector store

# -----------------------------------------------------------------------------
# Lab 2 — local artifacts
# -----------------------------------------------------------------------------
# Local ChromaDB persistence directory for embed/rerank notebooks.
LAB2_CHROMA_DIR=./lab-2-cohere-capabilities/.chroma
